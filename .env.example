# ── CosmosNL Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in your keys

# Anthropic Claude API Key (required for AI rewriter)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# NASA API Key (optional — DEMO_KEY works but is rate-limited)
# Get one free at: https://api.nasa.gov/
NASA_API_KEY=DEMO_KEY

# Pexels API Key (free — used for diverse article images including equipment photos)
# Get one free at: https://www.pexels.com/api/
# Without this key the app falls back to NASA Images API
PEXELS_API_KEY=your_pexels_key_here

# Site URL (used for SEO/og tags)
NEXT_PUBLIC_SITE_URL=https://cosmosnl.nl

# Site name
NEXT_PUBLIC_SITE_NAME=CosmosNL

# Google AdSense Publisher ID (add after approval)
# NEXT_PUBLIC_ADSENSE_ID=ca-pub-xxxxxxxxxxxxxxxxx

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
